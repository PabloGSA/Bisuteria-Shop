<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="max-w-7xl mx-auto px-4 py-10">

  <!-- Encabezado -->
  <div class="border-b border-gray-200 pb-6 mb-10">
    <p class="text-xs uppercase tracking-widest text-gray-400 mb-1">Romi Antonucci</p>
    <h1 class="text-3xl font-light text-gray-900 tracking-wide">Panel de Administración</h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

    <!-- Formulario -->
    <div class="lg:col-span-1">
      <h2 id="form-title" class="text-sm uppercase tracking-widest text-gray-900 font-semibold mb-6">Nuevo producto</h2>

      <div id="mensaje" class="hidden text-sm text-center py-2 mb-4"></div>

      <form id="producto-form" class="space-y-5">
        <input type="hidden" id="editando-id" value="" />

        <div>
          <label class="text-xs uppercase tracking-widest text-gray-500 block mb-1">Nombre</label>
          <input type="text" id="f-name" required class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent transition-colors" />
        </div>

        <div>
          <label class="text-xs uppercase tracking-widest text-gray-500 block mb-1">Descripción</label>
          <textarea id="f-description" required rows="3" class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent transition-colors resize-none"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-xs uppercase tracking-widest text-gray-500 block mb-1">Precio ($)</label>
            <input type="number" id="f-price" required min="0" step="0.01" class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent transition-colors" />
          </div>
          <div>
            <label class="text-xs uppercase tracking-widest text-gray-500 block mb-1">Stock</label>
            <input type="number" id="f-stock" required min="0" class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent transition-colors" />
          </div>
        </div>

        <div>
          <label class="text-xs uppercase tracking-widest text-gray-500 block mb-1">Categoría</label>
          <select id="f-category" class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent transition-colors capitalize">
            <option value="collares">collares</option>
            <option value="pulseras">pulseras</option>
            <option value="aretes">aretes</option>
            <option value="anillos">anillos</option>
          </select>
        </div>

        <div>
          <label class="text-xs uppercase tracking-widest text-gray-500 block mb-1">URL de la imagen</label>
          <input type="text" id="f-image" required placeholder="/images/collares/collar-1.jpeg" class="w-full border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent transition-colors" oninput="previewImage()" />
        </div>

        <!-- Vista previa -->
        <div id="img-preview" class="hidden h-40 w-full bg-gray-100 overflow-hidden">
          <img id="preview-img" src="" alt="Vista previa" class="w-full h-full object-cover" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" id="submit-btn" class="flex-1 bg-black text-white py-3 text-sm uppercase tracking-widest hover:bg-gray-800 transition disabled:opacity-50">
            Crear producto
          </button>
          <button type="button" id="cancel-btn" onclick="cancelarEdicion()" class="hidden flex-1 border border-black text-black py-3 text-sm uppercase tracking-widest hover:bg-gray-100 transition">
            Cancelar
          </button>
        </div>
      </form>
    </div>

    <!-- Lista de productos -->
    <div class="lg:col-span-2">
      <h2 class="text-sm uppercase tracking-widest text-gray-900 font-semibold mb-6">
        Productos <span id="producto-count" class="text-gray-400 font-normal"></span>
      </h2>
      <div id="productos-list" class="space-y-3">
        <p class="text-gray-400 text-sm uppercase tracking-widest">Cargando...</p>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>

<script>
  let productos = [];

  async function cargarProductos() {
    const res = await fetch('/api/products');
    productos = await res.json();
    renderProductos();
  }

  function renderProductos() {
    document.getElementById('producto-count').textContent = `(${productos.length})`;
    const list = document.getElementById('productos-list');

    if (productos.length === 0) {
      list.innerHTML = '<p class="text-gray-400 text-sm uppercase tracking-widest">No hay productos.</p>';
      return;
    }

    list.innerHTML = productos.map(p => `
      <div class="flex items-center gap-4 border border-gray-100 p-4 hover:border-gray-300 transition">
        <div class="w-16 h-16 flex-shrink-0 bg-gray-100 overflow-hidden">
          <img src="${p.image}" alt="${p.name}" class="w-full h-full object-cover" />
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-900 truncate">${p.name}</p>
          <p class="text-xs text-gray-400 uppercase tracking-widest">${p.category}</p>
          <p class="text-sm text-gray-700 mt-0.5">$${parseFloat(p.price).toFixed(2)} · Stock: ${p.stock}</p>
        </div>
        <div class="flex gap-2 flex-shrink-0">
          <button onclick="editarProducto('${p._id}')" class="border border-black text-black px-4 py-1.5 text-xs uppercase tracking-widest hover:bg-black hover:text-white transition">Editar</button>
          <button onclick="eliminarProducto('${p._id}')" class="border border-red-400 text-red-400 px-4 py-1.5 text-xs uppercase tracking-widest hover:bg-red-400 hover:text-white transition">Eliminar</button>
        </div>
      </div>
    `).join('');
  }

  function previewImage() {
    const url = document.getElementById('f-image').value;
    const preview = document.getElementById('img-preview');
    const img = document.getElementById('preview-img');
    if (url) {
      img.src = url;
      preview.classList.remove('hidden');
    } else {
      preview.classList.add('hidden');
    }
  }

  function editarProducto(id) {
    const p = productos.find(x => x._id === id);
    if (!p) return;

    document.getElementById('editando-id').value = id;
    document.getElementById('f-name').value = p.name;
    document.getElementById('f-description').value = p.description;
    document.getElementById('f-price').value = p.price;
    document.getElementById('f-stock').value = p.stock;
    document.getElementById('f-category').value = p.category;
    document.getElementById('f-image').value = p.image;
    previewImage();

    document.getElementById('form-title').textContent = 'Editar producto';
    document.getElementById('submit-btn').textContent = 'Actualizar';
    document.getElementById('cancel-btn').classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function cancelarEdicion() {
    document.getElementById('editando-id').value = '';
    document.getElementById('producto-form').reset();
    document.getElementById('img-preview').classList.add('hidden');
    document.getElementById('form-title').textContent = 'Nuevo producto';
    document.getElementById('submit-btn').textContent = 'Crear producto';
    document.getElementById('cancel-btn').classList.add('hidden');
    mostrarMensaje('');
  }

  async function eliminarProducto(id) {
    if (!confirm('¿Eliminar este producto?')) return;
    const res = await fetch(`/api/products/${id}`, { method: 'DELETE' });
    if (res.ok) {
      mostrarMensaje('Producto eliminado', false);
      cargarProductos();
    } else {
      mostrarMensaje('Error al eliminar', true);
    }
  }

  function mostrarMensaje(texto, esError = false) {
    const el = document.getElementById('mensaje');
    if (!texto) { el.classList.add('hidden'); return; }
    el.textContent = texto;
    el.className = `text-sm text-center py-2 mb-4 ${esError ? 'text-red-500' : 'text-green-600'}`;
    el.classList.remove('hidden');
  }

  document.getElementById('producto-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.textContent = 'Guardando...';

    const id = document.getElementById('editando-id').value;
    const body = {
      name: document.getElementById('f-name').value,
      description: document.getElementById('f-description').value,
      price: parseFloat(document.getElementById('f-price').value),
      stock: parseInt(document.getElementById('f-stock').value),
      category: document.getElementById('f-category').value,
      image: document.getElementById('f-image').value,
    };

    try {
      const res = id
        ? await fetch(`/api/products/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        : await fetch('/api/products', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });

      if (res.ok) {
        mostrarMensaje(id ? 'Producto actualizado' : 'Producto creado', false);
        cancelarEdicion();
        cargarProductos();
      } else {
        const err = await res.json();
        mostrarMensaje('Error: ' + err.message, true);
      }
    } catch {
      mostrarMensaje('Error de conexión', true);
    }

    btn.disabled = false;
    btn.textContent = id ? 'Actualizar' : 'Crear producto';
  });

  cargarProductos();
</script>
